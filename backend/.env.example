# Groq free tier (preferred): https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Alternative: OpenAI (paid quota)
# OPENAI_API_KEY=sk-...
PORT=3000
# Optional: use alternative RPC if rpc.sepolia.org returns 522
# SEPOLIA_RPC_URL=https://rpc.ankr.com/eth_sepolia

# For Join bonus (50 AURA on community/event join): contract owner's private key
# Must match deployer of AuraCredit. Redeploy contract after adding grantJoinBonus.
# BONUS_SIGNER_PRIVATE_KEY=0x...
# Optional: new contract address after redeploy
# AURA_CONTRACT_ADDRESS=0x...

# For Vercel/production: allow frontend origin (GitHub Pages URL)
# CORS_ORIGIN=https://YOUR_USERNAME.github.io
